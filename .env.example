# LLM Provider Configuration
# Options: anthropic, gemini, openai
LLM_PROVIDER=gemini

# Model Selection (optional - uses provider default if "auto")
# Anthropic: claude-sonnet-4-20250514, claude-opus-4-20250514
# Gemini: gemini-1.5-pro, gemini-1.5-flash
# OpenAI: gpt-4, gpt-4-turbo, gpt-3.5-turbo
LLM_MODEL=gemini-2.5-pro

# API Keys (only set the one you're using)
ANTHROPIC_API_KEY=your_anthropic_key_here
GEMINI_API_KEY=your_gemini_key_here
OPENAI_API_KEY=your_openai_key_here

# Model Parameters
MAX_TOKENS=4096
TEMPERATURE=0.0

# Application Settings
ENVIRONMENT=development
LOG_LEVEL=INFO

# Database (for future use)
DATABASE_URL=postgresql://localhost/autoauth

# FHIR Settings (mock endpoints for POC)
FHIR_BASE_URL=http://localhost:8080/fhir